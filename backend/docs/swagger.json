{
  "openapi": "3.0.0",
  "info": {
    "title": "CultureConnect API",
    "description": "Backend API for CultureConnect - Group 11. Handles authentication, user management, and data operations.",
    "version": "1.0.0",
    "contact": {
      "name": "Habeeb (Backend Developer)"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000/backend/api",
      "description": "Local PHP Dev Server"
    }
  ],
  "paths": {
    "/auth/signup.php": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Register a new Resident",
        "description": "Creates a new user account with Resident role. User code (RES-XXXX) is auto-generated by database trigger.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupRequest"
              },
              "example": {
                "name": "John Doe",
                "email": "john@email.com",
                "password": "mypassword",
                "address": "Hatfield",
                "area_id": 1
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Registration successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SignupResponse"
                },
                "example": {
                  "success": true,
                  "data": {
                    "message": "Registration successful",
                    "user": {
                      "user_ref_no": 15,
                      "name": "John Doe",
                      "email": "john@email.com",
                      "user_code": "RES-0003",
                      "status": "active"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "examples": {
                  "missing_fields": {
                    "value": {
                      "success": false,
                      "error": "Missing required fields: name, email"
                    }
                  },
                  "invalid_email": {
                    "value": {
                      "success": false,
                      "error": "Invalid email format"
                    }
                  },
                  "short_password": {
                    "value": {
                      "success": false,
                      "error": "Password must be at least 6 characters"
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Email already registered",
            "content": {
              "application/json": {
                "example": {
                  "success": false,
                  "error": "Email already registered"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "example": {
                  "success": false,
                  "error": "Registration failed: ..."
                }
              }
            }
          }
        }
      }
    },
    "/auth/login.php": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Login user",
        "description": "Authenticates user with email and password. Sets PHP session variables on success. After login, redirect to dashboard.php — the session handles role, name, etc.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "email": "john@email.com",
                "password": "mypassword"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                },
                "example": {
                  "success": true,
                  "data": {
                    "message": "Login successful",
                    "user": {
                      "user_ref_no": 15,
                      "name": "John Doe",
                      "email": "john@email.com",
                      "role": "Resident",
                      "area": "Hertfordshire North",
                      "status": "active"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing fields",
            "content": {
              "application/json": {
                "example": {
                  "success": false,
                  "error": "Missing required fields: email, password"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "example": {
                  "success": false,
                  "error": "Invalid email or password"
                }
              }
            }
          },
          "403": {
            "description": "Account rejected",
            "content": {
              "application/json": {
                "example": {
                  "success": false,
                  "error": "Your account has been rejected"
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout.php": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Logout user",
        "description": "Destroys the current PHP session. No request body needed. After logout, redirect to login page.",
        "responses": {
          "200": {
            "description": "Logout successful",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": {
                    "message": "Logged out successfully"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SignupRequest": {
        "type": "object",
        "required": ["name", "email", "password", "address", "area_id"],
        "properties": {
          "name": {
            "type": "string",
            "description": "User's full name",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User's email (must be unique)",
            "example": "john@email.com"
          },
          "password": {
            "type": "string",
            "minLength": 6,
            "description": "Password (minimum 6 characters)",
            "example": "mypassword"
          },
          "address": {
            "type": "string",
            "description": "User's address",
            "example": "Hatfield"
          },
          "area_id": {
            "type": "integer",
            "description": "Area ID from areas table",
            "enum": [1, 2, 3, 4, 5, 6],
            "example": 1
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "john@email.com"
          },
          "password": {
            "type": "string",
            "example": "mypassword"
          }
        }
      },
      "SignupResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              },
              "user": {
                "type": "object",
                "properties": {
                  "user_ref_no": { "type": "integer" },
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "user_code": { "type": "string" },
                  "status": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              },
              "user": {
                "type": "object",
                "properties": {
                  "user_ref_no": { "type": "integer" },
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "role": { "type": "string" },
                  "area": { "type": "string" },
                  "status": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string"
          }
        }
      },
      "Areas": {
        "type": "object",
        "description": "Available areas for the area_id dropdown",
        "properties": {
          "1": { "type": "string", "example": "Hertfordshire North" },
          "2": { "type": "string", "example": "Hertfordshire South" },
          "3": { "type": "string", "example": "Hertfordshire East" },
          "4": { "type": "string", "example": "Hertfordshire West" },
          "5": { "type": "string", "example": "Hertfordshire Town Centre" },
          "6": { "type": "string", "example": "Hertfordshire Central" }
        }
      }
    }
  }
}
